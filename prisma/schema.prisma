generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  MECHANIC
  CUSTOMER
  LIQUIDATOR
}

enum VehicleFuelType {
  GASOLINE
  DIESEL
  HYBRID
  ELECTRIC
  LPG
  CNG
  FLEX
  OTHER
}

enum VehicleTransmissionType {
  MANUAL
  AUTOMATIC
  CVT
  DUAL_CLUTCH
  OTHER
}

enum WorkOrderStatus {
  RECEIVED
  IN_DIAGNOSIS
  WAITING_APPROVAL
  WAITING_PARTS
  IN_REPAIR
  IN_PAINT
  READY_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum SelfInspectionStatus {
  DRAFT
  IN_PROGRESS
  SUBMITTED
  UNDER_REVIEW
  REVIEWED
  CONVERTED_TO_WORK_ORDER
  CANCELLED
}

enum SelfInspectionRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SelfInspectionReason {
  PREVENTIVE_MAINTENANCE
  MECHANICAL_FAILURE
  STRANGE_NOISE
  DASHBOARD_WARNING_LIGHTS
  COLLISION_DAMAGE
  BODY_PAINT_DAMAGE
  PRE_PURCHASE
  OTHER
}

enum SelfInspectionSource {
  CUSTOMER_PORTAL
  SECURE_LINK
  STAFF_ASSISTED
}

enum SelfInspectionAnswerType {
  BOOLEAN
  SINGLE_CHOICE
  MULTI_CHOICE
  TEXT
  LONG_TEXT
  NUMBER
  DATE
}

enum SelfInspectionPhotoType {
  FRONTAL_FULL
  REAR_FULL
  LEFT_SIDE_FULL
  RIGHT_SIDE_FULL
  DASHBOARD_ON
  ODOMETER
  FRONT_LEFT_TIRE
  FRONT_RIGHT_TIRE
  REAR_LEFT_TIRE
  REAR_RIGHT_TIRE
  PRIMARY_DAMAGE
  DAMAGE_CONTEXT
  ENGINE
  TRUNK
  FRONT_INTERIOR
  REAR_INTERIOR
  VEHICLE_DOCUMENTS
  COLLISION_ZONE
  FLUID_LEAK
  DASHBOARD_WARNING_DETAIL
  BROKEN_PART
  VIN_VISIBLE
  OTHER
}

enum SelfInspectionNoteType {
  CUSTOMER_OBSERVATION
  CUSTOMER_BACKGROUND
  CUSTOMER_INSTRUCTION
  CUSTOMER_AVAILABILITY
  INTERNAL_REVIEW
  SYSTEM_SUMMARY
}

enum SelfInspectionDepartment {
  MECHANICS
  BODY_PAINT
  ELECTRICAL
  INSURANCE
  GENERAL_DIAGNOSIS
}

enum ReviewRecommendedNextStep {
  SCHEDULE_DIAGNOSTIC
  REQUEST_TOW
  REFER_MECHANICS
  REFER_BODY_PAINT
  REFER_ELECTRICAL
  PREPARE_QUOTE
  REQUEST_MORE_EVIDENCE
  FOLLOW_UP_CALL
}

enum SelfInspectionOperationalOutcome {
  REMOTE_QUOTE
  REQUEST_MORE_INFORMATION
  REQUIRE_IN_PERSON_INSPECTION
}

enum StockMovementType {
  INITIAL
  ENTRY
  OUT
  ADJUSTMENT
}

enum StockMovementSourceType {
  INVENTORY
  WORK_ORDER
}

enum BudgetStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  REQUEST_CHANGES
  PARTIALLY_APPROVED
  CONVERTED_TO_WORK_ORDER
}

enum BudgetItemType {
  PART
  LABOR
  SUPPLY
}

model User {
  id                          String                    @id @default(cuid())
  name                        String
  email                       String                    @unique
  passwordHash                String
  role                        UserRole
  active                      Boolean                   @default(true)
  clientId                    String?                   @unique
  createdAt                   DateTime                  @default(now())
  updatedAt                   DateTime                  @updatedAt
  client                      Client?                   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  sessions                    Session[]
  createdWorkOrders           WorkOrder[]               @relation("WorkOrderCreatedBy")
  updatedWorkOrders           WorkOrder[]               @relation("WorkOrderUpdatedBy")
  assignedWorkOrders          WorkOrder[]               @relation("WorkOrderAssignedTechnician")
  uploadedWorkOrderEvidences  WorkOrderEvidence[]       @relation("WorkOrderEvidenceUploadedBy")
  statusChanges               WorkOrderStatusLog[]
  reviewedSelfInspections     SelfInspection[]          @relation("SelfInspectionReviewer")
  selfInspectionNotes         SelfInspectionNote[]      @relation("SelfInspectionNoteCreatedBy")
  selfInspectionReviews       SelfInspectionReview[]    @relation("SelfInspectionReviewReviewedBy")
  selfInspectionStatusChanges SelfInspectionStatusLog[] @relation("SelfInspectionStatusChangedBy")
  stockMovements              StockMovement[]           @relation("StockMovementCreatedBy")
  workOrderParts              WorkOrderPart[]           @relation("WorkOrderPartCreatedBy")
  createdBudgets              Budget[]                  @relation("BudgetCreatedBy")
  updatedBudgets              Budget[]                  @relation("BudgetUpdatedBy")
  budgetStatusChanges         BudgetStatusLog[]
  insuranceCases              InsuranceCase[]           @relation("InsuranceCaseLiquidator")
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Client {
  id              String           @id @default(cuid())
  fullName        String
  localIdentifier String?          @db.VarChar(32)
  phone           String           @db.VarChar(32)
  email           String           @db.VarChar(255)
  address         String?
  isWorkshopClient Boolean         @default(true)
  deletedAt       DateTime?
  purgeAt         DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  user            User?
  vehicles        Vehicle[]
  workOrders      WorkOrder[]
  selfInspections SelfInspection[]
  budgets         Budget[]
  insuranceCases  InsuranceCase[]

  @@index([fullName])
  @@index([email])
  @@index([isWorkshopClient, deletedAt])
  @@index([deletedAt, purgeAt])
}

model Vehicle {
  id              String                   @id @default(cuid())
  clientId        String
  plate           String?                  @unique @db.VarChar(16)
  vin             String                   @unique @db.VarChar(32)
  make            String
  model           String
  year            Int
  color           String?
  mileage         Int?
  fuelType        VehicleFuelType?
  transmission    VehicleTransmissionType?
  deletedAt       DateTime?
  purgeAt         DateTime?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  client          Client                   @relation(fields: [clientId], references: [id], onDelete: Restrict)
  workOrders      WorkOrder[]
  selfInspections SelfInspection[]
  budgets         Budget[]
  insuranceCases  InsuranceCase[]

  @@index([clientId])
  @@index([make, model])
  @@index([deletedAt, purgeAt])
}

model WorkOrder {
  id                   String               @id @default(cuid())
  clientId             String
  vehicleId            String
  insuranceCaseId      String?
  orderNumber          String               @unique
  reason               String
  initialDiagnosis     String?
  status               WorkOrderStatus      @default(RECEIVED)
  intakeDate           DateTime             @default(now())
  estimatedDate        DateTime?
  closedDate           DateTime?
  notes                String?
  createdById          String
  updatedById          String?
  assignedTechnicianId String?
  deletedAt            DateTime?
  purgeAt              DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  client               Client               @relation(fields: [clientId], references: [id], onDelete: Restrict)
  vehicle              Vehicle              @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  insuranceCase        InsuranceCase?       @relation(fields: [insuranceCaseId], references: [id], onDelete: SetNull)
  createdBy            User                 @relation("WorkOrderCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy            User?                @relation("WorkOrderUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  assignedTechnician   User?                @relation("WorkOrderAssignedTechnician", fields: [assignedTechnicianId], references: [id], onDelete: SetNull)
  statusLogs           WorkOrderStatusLog[]
  selfInspections      SelfInspection[]
  evidences            WorkOrderEvidence[]
  parts                WorkOrderPart[]
  budget           Budget?

  @@index([clientId, intakeDate])
  @@index([vehicleId, intakeDate])
  @@index([insuranceCaseId, intakeDate])
  @@index([status])
  @@index([assignedTechnicianId, intakeDate])
  @@index([deletedAt, purgeAt])
}

model Repuesto {
  id           String          @id @default(cuid())
  name         String
  code         String          @unique @db.VarChar(80)
  unitPrice    Int             @default(0)
  currentStock Int             @default(0)
  minimumStock Int             @default(0)
  deletedAt    DateTime?
  purgeAt      DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  movements    StockMovement[]
  workOrders   WorkOrderPart[]

  @@index([name])
  @@index([currentStock, minimumStock])
  @@index([deletedAt, purgeAt])
}

model WorkOrderPart {
  id          String    @id @default(cuid())
  workOrderId String
  repuestoId  String
  quantity    Int
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  repuesto    Repuesto  @relation(fields: [repuestoId], references: [id], onDelete: Restrict)
  createdBy   User      @relation("WorkOrderPartCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@unique([workOrderId, repuestoId])
  @@index([repuestoId])
}

model StockMovement {
  id            String                   @id @default(cuid())
  repuestoId    String
  type          StockMovementType
  quantity      Int
  previousStock Int
  newStock      Int
  reason        String?
  sourceType    StockMovementSourceType?
  sourceId      String?
  createdById   String?
  createdAt     DateTime                 @default(now())
  repuesto      Repuesto                 @relation(fields: [repuestoId], references: [id], onDelete: Restrict)
  createdBy     User?                    @relation("StockMovementCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([repuestoId, createdAt])
  @@index([type, createdAt])
  @@index([sourceType, sourceId])
}

model WorkOrderEvidence {
  id           String    @id @default(cuid())
  workOrderId  String
  uploadedById String
  fileUrl      String
  storageKey   String    @unique
  fileName     String
  mimeType     String
  sizeBytes    Int
  note         String?
  createdAt    DateTime  @default(now())
  workOrder    WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  uploadedBy   User      @relation("WorkOrderEvidenceUploadedBy", fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([workOrderId, createdAt])
}

model WorkOrderStatusLog {
  id             String           @id @default(cuid())
  workOrderId    String
  previousStatus WorkOrderStatus?
  nextStatus     WorkOrderStatus
  note           String?
  changedById    String
  changedAt      DateTime         @default(now())
  workOrder      WorkOrder        @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  changedBy      User             @relation(fields: [changedById], references: [id], onDelete: Restrict)

  @@index([workOrderId, changedAt])
}

model SelfInspection {
  id                    String                         @id @default(cuid())
  customerId            String
  vehicleId             String?
  workOrderId           String?
  status                SelfInspectionStatus           @default(DRAFT)
  sourceChannel         SelfInspectionSource           @default(SECURE_LINK)
  accessTokenHash       String?                        @unique
  accessTokenExpiresAt  DateTime?
  inspectionReason      SelfInspectionReason?
  inspectionReasonOther String?
  mainComplaint         String?
  canDrive              Boolean?
  startedAt             DateTime                       @default(now())
  submittedAt           DateTime?
  reviewedAt            DateTime?
  reviewerId            String?
  operationalOutcome    SelfInspectionOperationalOutcome?
  overallRiskLevel      SelfInspectionRiskLevel        @default(LOW)
  summaryGenerated      String?
  completionPercent     Int                            @default(0)
  lastCompletedStep     Int                            @default(1)
  deletedAt             DateTime?
  purgeAt               DateTime?
  createdAt             DateTime                       @default(now())
  updatedAt             DateTime                       @updatedAt
  customer              Client                         @relation(fields: [customerId], references: [id], onDelete: Restrict)
  vehicle               Vehicle?                       @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  workOrder             WorkOrder?                     @relation(fields: [workOrderId], references: [id], onDelete: SetNull)
  reviewer              User?                          @relation("SelfInspectionReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  vehicleSnapshot       SelfInspectionVehicleSnapshot?
  answers               SelfInspectionAnswer[]
  photos                SelfInspectionPhoto[]
  notes                 SelfInspectionNote[]
  reviews               SelfInspectionReview[]
  statusLogs            SelfInspectionStatusLog[]
  budgets               Budget[]

  @@index([customerId, createdAt])
  @@index([vehicleId, createdAt])
  @@index([status, overallRiskLevel])
  @@index([submittedAt])
  @@index([deletedAt, purgeAt])
}

model SelfInspectionVehicleSnapshot {
  id               String                  @id @default(cuid())
  selfInspectionId String                  @unique
  plate            String?                 @db.VarChar(16)
  vin              String?                 @db.VarChar(32)
  make             String
  model            String
  year             Int
  color            String?
  mileage          Int
  fuelType         VehicleFuelType
  transmission     VehicleTransmissionType
  starts           Boolean
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  selfInspection   SelfInspection          @relation(fields: [selfInspectionId], references: [id], onDelete: Cascade)

  @@index([plate])
  @@index([vin])
}

model SelfInspectionAnswer {
  id               String                   @id @default(cuid())
  selfInspectionId String
  section          String                   @db.VarChar(64)
  questionKey      String                   @db.VarChar(80)
  questionLabel    String                   @db.VarChar(255)
  answerType       SelfInspectionAnswerType
  answerValue      Json
  severity         SelfInspectionRiskLevel?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  selfInspection   SelfInspection           @relation(fields: [selfInspectionId], references: [id], onDelete: Cascade)

  @@unique([selfInspectionId, questionKey])
  @@index([selfInspectionId, section])
  @@index([severity])
}

model SelfInspectionPhoto {
  id               String                  @id @default(cuid())
  selfInspectionId String
  photoType        SelfInspectionPhotoType
  fileUrl          String
  storageKey       String                  @unique
  fileName         String
  mimeType         String
  sizeBytes        Int
  sortOrder        Int                     @default(0)
  isRequired       Boolean
  comment          String?
  createdAt        DateTime                @default(now())
  selfInspection   SelfInspection          @relation(fields: [selfInspectionId], references: [id], onDelete: Cascade)

  @@index([selfInspectionId, photoType])
}

model SelfInspectionNote {
  id               String                 @id @default(cuid())
  selfInspectionId String
  noteType         SelfInspectionNoteType
  content          String
  createdById      String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  selfInspection   SelfInspection         @relation(fields: [selfInspectionId], references: [id], onDelete: Cascade)
  createdBy        User?                  @relation("SelfInspectionNoteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([selfInspectionId, noteType])
}

model SelfInspectionReview {
  id                        String                    @id @default(cuid())
  selfInspectionId          String
  reviewedById              String
  riskAssessment            SelfInspectionRiskLevel
  internalSummary           String
  recommendedNextStep       ReviewRecommendedNextStep
  departmentSuggestion      SelfInspectionDepartment?
  createWorkOrderSuggestion Boolean                   @default(false)
  createQuoteSuggestion     Boolean                   @default(false)
  reviewedAt                DateTime                  @default(now())
  selfInspection            SelfInspection            @relation(fields: [selfInspectionId], references: [id], onDelete: Cascade)
  reviewedBy                User                      @relation("SelfInspectionReviewReviewedBy", fields: [reviewedById], references: [id], onDelete: Restrict)

  @@index([selfInspectionId, reviewedAt])
}

model SelfInspectionStatusLog {
  id               String                @id @default(cuid())
  selfInspectionId String
  previousStatus   SelfInspectionStatus?
  nextStatus       SelfInspectionStatus
  note             String?
  changedById      String?
  changedAt        DateTime              @default(now())
  selfInspection   SelfInspection        @relation(fields: [selfInspectionId], references: [id], onDelete: Cascade)
  changedBy        User?                 @relation("SelfInspectionStatusChangedBy", fields: [changedById], references: [id], onDelete: SetNull)

  @@index([selfInspectionId, changedAt])
}

model Budget {
  id                String            @id @default(cuid())
  budgetNumber      String            @unique
  clientId          String
  vehicleId         String
  insuranceCaseId   String?
  selfInspectionId  String?
  workOrderId       String?           @unique
  title             String
  summary           String?
  status            BudgetStatus      @default(DRAFT)
  subtotalParts     Int               @default(0)
  subtotalLabor     Int               @default(0)
  subtotalSupplies  Int               @default(0)
  totalAmount       Int               @default(0)
  sentAt            DateTime?
  approvedAt        DateTime?
  rejectedAt        DateTime?
  createdById       String
  updatedById       String?
  deletedAt         DateTime?
  purgeAt           DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  client            Client            @relation(fields: [clientId], references: [id], onDelete: Restrict)
  vehicle           Vehicle           @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  insuranceCase     InsuranceCase?    @relation(fields: [insuranceCaseId], references: [id], onDelete: SetNull)
  selfInspection    SelfInspection?   @relation(fields: [selfInspectionId], references: [id], onDelete: SetNull)
  workOrder         WorkOrder?        @relation(fields: [workOrderId], references: [id], onDelete: SetNull)
  createdBy         User              @relation("BudgetCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy         User?             @relation("BudgetUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  items             BudgetItem[]
  statusLogs        BudgetStatusLog[]

  @@index([clientId, createdAt])
  @@index([vehicleId, createdAt])
  @@index([insuranceCaseId, createdAt])
  @@index([status, createdAt])
  @@index([selfInspectionId])
  @@index([deletedAt, purgeAt])
}

model InsuranceCase {
  id               String               @id @default(cuid())
  caseNumber       String               @unique
  claimNumber      String?              @db.VarChar(64)
  policyNumber     String?              @db.VarChar(64)
  clientId         String
  vehicleId        String
  liquidatorId     String
  createdFromLiquidatorPortal Boolean   @default(false)
  ownerFullName    String               @default("")
  ownerPhone       String               @default("") @db.VarChar(32)
  ownerEmail       String?              @db.VarChar(255)
  ownerAddress     String?
  incidentDate     DateTime
  incidentLocation String?
  description      String
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  client           Client               @relation(fields: [clientId], references: [id], onDelete: Restrict)
  vehicle          Vehicle              @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  liquidator       User                 @relation("InsuranceCaseLiquidator", fields: [liquidatorId], references: [id], onDelete: Restrict)
  photos           InsuranceCasePhoto[]
  budgets          Budget[]
  workOrders       WorkOrder[]

  @@index([liquidatorId, createdAt])
  @@index([clientId, createdAt])
  @@index([vehicleId, createdAt])
}

model InsuranceCasePhoto {
  id              String         @id @default(cuid())
  insuranceCaseId String
  fileUrl         String
  storageKey      String         @unique
  fileName        String
  mimeType        String
  sizeBytes       Int
  note            String?
  createdAt       DateTime       @default(now())
  insuranceCase   InsuranceCase  @relation(fields: [insuranceCaseId], references: [id], onDelete: Cascade)

  @@index([insuranceCaseId, createdAt])
}

model BudgetItem {
  id                 String                 @id @default(cuid())
  budgetId           String
  referenceCatalogId String?
  itemType           BudgetItemType
  description        String
  referenceCode      String?                @db.VarChar(40)
  quantity           Int
  unitPrice          Int
  subtotal           Int
  sourceLabel        String?
  sourceUrl          String?
  note               String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  budget             Budget                 @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  referenceCatalog   BudgetReferenceCatalog? @relation(fields: [referenceCatalogId], references: [id], onDelete: SetNull)

  @@index([budgetId, itemType])
  @@index([referenceCatalogId])
}

model BudgetStatusLog {
  id             String        @id @default(cuid())
  budgetId       String
  previousStatus BudgetStatus?
  nextStatus     BudgetStatus
  note           String?
  changedById    String
  changedAt      DateTime      @default(now())
  budget         Budget        @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  changedBy      User          @relation(fields: [changedById], references: [id], onDelete: Restrict)

  @@index([budgetId, changedAt])
}

model BudgetReferenceCatalog {
  id                   String          @id @default(cuid())
  itemType             BudgetItemType
  name                 String
  referenceCode        String?         @unique @db.VarChar(40)
  unitPrice            Int
  sourceLabel          String
  sourceUrl            String?
  vehicleCompatibility String?
  active               Boolean         @default(true)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  items                BudgetItem[]

  @@index([itemType, active])
  @@index([name])
}
