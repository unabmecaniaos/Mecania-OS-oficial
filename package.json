{
  "name": "mecaniaos",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "prisma generate && next build --webpack",
    "start": "next start -H 0.0.0.0 -p 3000",
    "start:prod": "sh ./scripts/start-prod.sh",
    "postinstall": "prisma generate",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:if-empty": "tsx prisma/seed-if-empty.ts",
    "db:bootstrap": "tsx scripts/bootstrap-admin.ts",
    "jira:issue:get": "tsx tools/jira/cli.ts issue:get",
    "jira:issue:list-subtasks": "tsx tools/jira/list-subtasks.ts",
    "jira:issue:comment": "tsx tools/jira/cli.ts issue:comment",
    "jira:issue:update-description": "tsx tools/jira/cli.ts issue:update-description",
    "jira:issue:transition": "tsx tools/jira/cli.ts issue:transition",
    "jira:issue:create": "tsx tools/jira/cli.ts issue:create",
    "jira:issue:bulk-update": "tsx tools/jira/bulk-update-descriptions.ts",
    "jira:sprint:current": "tsx tools/jira/cli.ts sprint:current",
    "jira:sprint:create": "tsx tools/jira/cli.ts sprint:create",
    "jira:sprint:sync": "tsx tools/jira/cli.ts sprint:sync",
    "studio": "prisma studio",
    "docker:db:up": "docker compose up -d db",
    "docker:db:down": "docker compose down",
    "docker:db:logs": "docker compose logs -f db",
    "docker:dev:up": "docker compose --profile dev up -d --build --force-recreate --renew-anon-volumes db app-dev",
    "docker:dev:down": "docker compose --profile dev down --remove-orphans",
    "docker:dev:logs": "docker compose --profile dev logs -f app-dev",
    "docker:dev:db:push": "docker compose --profile dev exec app-dev pnpm db:push",
    "docker:dev:seed": "docker compose --profile dev exec app-dev pnpm db:seed",
    "docker:dev:reset": "docker compose --profile dev down -v --remove-orphans",
    "docker:app:up": "docker compose --profile app up -d --build --force-recreate",
    "docker:app:down": "docker compose --profile app down",
    "docker:prod:up": "docker compose -f docker-compose.dockploy.yml up -d --build",
    "docker:prod:down": "docker compose -f docker-compose.dockploy.yml down"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.18.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "jose": "^6.2.1",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^6.18.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
